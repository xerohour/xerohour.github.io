<svg xmlns="http://www.w3.org/2000/svg" width="300" height="80" viewBox="0 0 300 80">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1f35;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0a0e1a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="textGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#00d9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7b2cbf;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="300" height="80" rx="8" fill="url(#bgGrad)" stroke="#2d3748" stroke-width="1"/>
  
  <!-- Phone Icon -->
  <circle cx="40" cy="40" r="25" fill="url(#textGrad)" opacity="0.2"/>
  <path d="M35 32 C35 32, 37 35, 40 38 C43 35, 45 32, 45 32 C44 30, 42 29, 40 30 C38 29, 36 30, 35 32 Z" fill="url(#textGrad)"/>
  <path d="M33 45 C33 45, 36 48, 40 48 C44 48, 47 45, 47 45" stroke="url(#textGrad)" stroke-width="2" fill="none" stroke-linecap="round"/>
  
  <!-- Phone Text -->
  <text x="75" y="35" font-family="Inter, Arial, sans-serif" font-size="11" fill="#94a3b8">Phone</text>
  <text x="75" y="55" font-family="JetBrains Mono, Consolas, monospace" font-size="16" font-weight="700" fill="url(#textGrad)">502-251-1337</text>
</svg>
